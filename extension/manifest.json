{
  "manifest_version": 3,
  "name": "Nimbus Player for Google Drive",
  "description": "Mở video Google Drive trực tiếp trong Nimbus Player.",
  "version": "0.1.0",
  "action": {
    "default_title": "Nimbus Player",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "https://drive.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://drive.google.com/*"
      ],
      "js": [
        "drive-reference.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
